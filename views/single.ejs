<% } %>

</div>

  <%- include("./users/commentBox") %>



<%- include("./footer") %>
<!-- Video.js JS -->
<script src="https://vjs.zencdn.net/8.10.0/video.min.js"></script>

<script>
  var player = videojs('my-video', {
    fluid: true,
    playbackRates: [0.5, 1, 1.5, 2]
  });

  // Auto buffer ready
  player.ready(function(){
    player.preload('auto');
  });
</script>
  
  <script>
  const shareBtn = document.getElementById('shareBtn');

  shareBtn.addEventListener('click', async () => {
    const shareData = {
      title: '<%= post.title %>',
      text: '<%= post.title %>',
      url: '<%= websiteUrl %>/videos/<%= post.routeName %>'
    };

    try {
      if (navigator.share) {
        // Use Web Share API on mobile browsers
        await navigator.share(shareData);
        alert('Shared successfully!');
      } else {
        // Fallback for desktop or browsers without Web Share API
        const shareText = `${shareData.title}\n${shareData.text}\n${shareData.url}`;
        prompt('Copy the link below to share:', shareText);
      }
    } catch (err) {
      console.error('Failed to share:', err);
    }
  });
  
</script>
<!-- Update View -->
<script>
setTimeout(function(){

  const routeName = "<%= post.routeName %>";

  // cookie read
  function getCookie(name){
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if(parts.length === 2) return parts.pop().split(';').shift();
  }

  // cookie data
  let viewsCookie = getCookie("views");

  let views = [];

  if(viewsCookie){
    try{
      views = JSON.parse(viewsCookie);
    }catch(e){
      views = [];
    }
  }

  // check current routeName
  if(!views.includes(routeName)){

    // add routeName
    views.push(routeName);

    // update cookie
    document.cookie =
      "views=" + JSON.stringify(views) +
      "; path=/; max-age=" + (60*60*24*365);

    // send to server
    fetch("/<%= post._id %>",{
      method:"POST"
    });

  }

},1000);
</script>
</body>
</html>