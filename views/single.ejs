<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">


  <!-- Video.js CSS -->
  <link href="https://vjs.zencdn.net/8.10.0/video-js.css" rel="stylesheet" />
  <link href="/css/single.css" rel="stylesheet" />

  <!-- HTML Meta Tags -->
  <title><%= post.title %> - <%= websiteName %></title>
  <meta name="description" content="<%= post.shortDescription %>">
  
  <meta name="theme-color" content="#007bff">
  <meta name="googlebot" content="index, follow, max-image-preview:large">
  <meta name="robots" content="index, follow">
  <meta name="keywords" content="<%= post.category %>" />
  <link rel="icon" href="<%= websiteFavicon %>" />
  <meta name="author" content="<%= websiteName %>">
  <link rel="canonical" href="<%= websiteUrl %>/videos/<%= post.routeName %>" />
  
  <!-- Facebook Meta Tags -->
  <meta property="og:url" content="<%= websiteUrl %>/videos/<%= post.routeName %>">
  <meta property="og:type" content="article">
  <meta property="og:title" content="<%= post.title %> - <%= websiteName %>">
  <meta property="og:description" content="<%= post.shortDescription %>">
  <meta property="og:image" content="<%= post.imageLink %>">
  
  <!-- Twitter Meta Tags -->
  <meta name="twitter:card" content="summary_large_image">
  <meta property="twitter:domain" content="links.p9x9.com">
  <meta property="twitter:url" content="<%= websiteUrl %>/videos/<%= post.routeName %>">
  <meta name="twitter:title" content="<%= post.title %> - <%= websiteName %>">
  <meta name="twitter:description" content="<%= post.shortDescription %>">
  <meta name="twitter:image" content="<%= post.imageLink %>">
  
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "<%= websiteUrl %>/videos/<%= post.routeName %>"
    },
    "headline": "<%= post.title %>",
    "description": "<%= post.shortDescription %>",
    "image": "<%= post.imageLink %>",  
    "author": {
      "@type": "Organization",
      "name": "<%= websiteName %>",
      "url": "<%= websiteUrl %>"
    },  
    "publisher": {
      "@type": "Organization",
      "name": "<%= websiteName %>",
      "logo": {
        "@type": "ImageObject",
        "url": "<%= websiteFavicon %>"
      }
    },
    "datePublished": "<%= post.date %>",
    "dateModified": "<%= post.updateDate %>"
  }
  </script>

</head>
<body>
<%- include("./nav") %>
<%- include("./ad/ad") %>
