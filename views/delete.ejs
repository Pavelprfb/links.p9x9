<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Delete Posts</title>

<!-- SVG Favicon (Delete Icon) -->
<link rel="icon" type="image/svg+xml" 
href="data:image/svg+xml,
<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'>
<text y='420' font-size='420'>🗑️</text>
</svg>">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Segoe UI', sans-serif;
}

body{
  background:#121212;
  color:#fff;
  padding:20px;
  display:flex;
  justify-content:center;
}

.container{
  width:100%;
  max-width:700px;
}

h2{
  text-align:center;
  margin-bottom:20px;
  font-weight:600;
}

.card{
  background:#1f1f1f;
  padding:14px 16px;
  margin-bottom:12px;
  border-radius:10px;
  border:1px solid #333;
  display:flex;
  justify-content:space-between;
  align-items:center;
  transition:0.3s;
  box-shadow:0 6px 18px rgba(0,0,0,0.4);
}

.card:hover{
  transform:translateY(-3px);
  box-shadow:0 10px 25px rgba(0,0,0,0.6);
}

.title{
  font-size:14px;
  word-break:break-word;
}

button{
  padding:7px 12px;
  border:none;
  border-radius:6px;
  background:#ff5722;
  color:#fff;
  font-weight:600;
  cursor:pointer;
  display:flex;
  align-items:center;
  gap:6px;
  transition:0.3s;
}

button:hover{
  background:#e64a19;
}

.empty{
  text-align:center;
  margin-top:30px;
  opacity:0.7;
}

@media(max-width:480px){
  .card{
    flex-direction:column;
    align-items:flex-start;
    gap:10px;
  }

  button{
    width:100%;
    justify-content:center;
  }
}
</style>
</head>

<body>

<div class="container">

<h2><i class="fa fa-trash"></i> Delete Posts</h2>

<% if(data.length === 0){ %>
  <div class="empty">
    <i class="fa fa-info-circle"></i> No posts available
  </div>
<% } %>

<% data.slice().reverse().forEach(function(post){ %>

  <div class="card">
    <div class="title"><%= post.title %></div>

    <form action="/delete/<%= post._id %>?_method=DELETE" method="POST">
      <button type="submit" onclick="return confirm('Are you sure you want to delete this post?')">
        <i class="fa fa-trash"></i> Delete
      </button>
    </form>
  </div>

<% }); %>

</div>

</body>
</html>