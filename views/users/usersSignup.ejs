<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Signup - Links.P9X9</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

/* wrapper */

.main-wrapper{
display:flex;
justify-content:center;
min-height:100vh;
background:#ffffff;
}

.container{
width:100%;
max-width:380px;
padding:20px;
}

.logoForm{
text-align:center;
font-size:28px;
font-weight:700;
color:#007bff;
margin-bottom:25px;
}

.card{
background:#fff;
padding:30px;
border-radius:12px;
}

.card h2{
text-align:center;
margin-bottom:20px;
color:#333;
}

/* inputs */

.input-group{
position:relative;
margin-bottom:10px;
}

.input-group .fa-phone, .input-group .fa-lock, .input-group .fa-user{
position:absolute;
top:50%;
left:12px;
transform:translateY(-50%);
color:#888;
}

.input-group input{
width:100%;
padding:12px 40px 12px 38px;
border:1px solid #ddd;
border-radius:8px;
font-size:15px;
outline:none;
}

.input-group input:focus{
border-color:#007bff;
}

/* password toggle */

.togglePass{
position:absolute;
right:12px;
top:50%;
transform:translateY(-50%);
cursor:pointer;
color:#777;
display:none;
}

/* validation */

.validation{
font-size:13px;
margin-bottom:12px;
color:#999;
}

.validation.success{
color:green;
}

.validation.error{
color:red;
}

/* password rules */

.pass-rules{
font-size:13px;
margin-bottom:15px;
display:none;
}

.pass-rules div{
margin:4px 0;
color:#999;
}

.pass-rules .valid{
color:green;
}

.pass-rules i{
margin-right:6px;
}

/* file upload */

.file-upload{
margin-bottom:10px;
}

.file-upload label{
display:block;
padding:10px;
border:1px dashed #ccc;
border-radius:8px;
text-align:center;
cursor:pointer;
font-size:14px;
color:#555;
}

.file-upload input{
display:none;
}

/* image preview */

.preview{
text-align:center;
margin-bottom:18px;
}

.preview img{
width:80px;
height:80px;
border-radius:50%;
object-fit:cover;
display:none;
border:3px solid #eee;
}

/* button */

button{
width:100%;
padding:12px;
border:none;
border-radius:8px;
background:#007bff;
color:white;
font-size:16px;
font-weight:600;
cursor:pointer;
transition:.3s;
}

button:hover{
background:#0056d2;
}

/* footer */

.footer-text{
text-align:center;
margin-top:15px;
font-size:14px;
}

.footer-text a{
color:#007bff;
text-decoration:none;
font-weight:600;
}

</style>
</head>

<body>

  <%- include("./../nav") %>
<div class="main-wrapper">

<div class="container">

<div class="logoForm">
  
</div>

<div class="card">

<h2><i class="fa-solid fa-user-plus"></i> Signup</h2>

<form action="/users/signup" method="POST" enctype="multipart/form-data">

<!-- Phone -->

<div class="input-group">
<i class="fa-solid fa-user"></i>
<input type="text" id="name" name="name" placeholder="Your Name" required>
</div>
<div class="input-group">
<i class="fa-solid fa-phone"></i>
<input type="text" id="number" name="number" placeholder="Phone Number" required>
</div>

<div id="numberMsg" class="validation"></div>

<!-- Password -->

<div class="input-group">
<i class="fa-solid fa-lock"></i>

<input type="password" id="password" name="password" placeholder="Password" required>

<i class="fa-solid fa-eye togglePass" id="togglePass"></i>

</div>

<!-- Password Rules -->

<div class="pass-rules" id="passRules">

<div id="upper"><i class="fa-solid fa-circle"></i> 1 Uppercase</div>
<div id="lower"><i class="fa-solid fa-circle"></i> 1 Lowercase</div>
<div id="numberRule"><i class="fa-solid fa-circle"></i> 1 Number</div>
<div id="special"><i class="fa-solid fa-circle"></i> 1 Special Character</div>
<div id="length"><i class="fa-solid fa-circle"></i> Minimum 8 Characters</div>

</div>

<!-- Image -->

<div class="file-upload">
<label for="file">
<i class="fa-solid fa-image"></i> Upload Profile Picture
</label>

<input type="file" id="file" name="profilePic" accept="image/*" required>
</div>

<div class="preview">
<img id="previewImg">
</div>

<button type="submit">
<i class="fa-solid fa-user-check"></i> Create Account
</button>

</form>

<div class="footer-text">
Already have account? <a href="/users/login">Login</a>
</div>

</div>
</div>
</div>

  <%- include("./../footer") %>
<script>

/* phone validation */

const numberInput=document.getElementById("number");
const numberMsg=document.getElementById("numberMsg");

numberInput.addEventListener("input",function(){

const value=this.value;

if(!/^[0-9]*$/.test(value)){

numberMsg.textContent="Only numbers allowed";
numberMsg.className="validation error";

this.value=value.replace(/[^0-9]/g,'');

}
else{

numberMsg.textContent="Valid number format";
numberMsg.className="validation success";

}

});


/* password rules */

const password=document.getElementById("password");
const rules=document.getElementById("passRules");
const togglePass=document.getElementById("togglePass");

const upper=document.getElementById("upper");
const lower=document.getElementById("lower");
const numberRule=document.getElementById("numberRule");
const special=document.getElementById("special");
const length=document.getElementById("length");

password.addEventListener("input",function(){

const val=this.value;

if(val.length>0){

rules.style.display="block";
togglePass.style.display="block";

}else{

rules.style.display="none";
togglePass.style.display="none";

}

check(/[A-Z]/,upper);
check(/[a-z]/,lower);
check(/[0-9]/,numberRule);
check(/[\W_]/,special);
check(val.length>=8,length);

});


function check(rule,element){

if(typeof rule==="boolean"){

rule ? valid(element) : invalid(element);

}else{

rule.test(password.value) ? valid(element) : invalid(element);

}

}


function valid(el){

el.classList.add("valid");
el.innerHTML='<i class="fa-solid fa-check"></i> '+el.textContent;

}

function invalid(el){

el.classList.remove("valid");
el.innerHTML='<i class="fa-solid fa-circle"></i> '+el.textContent;

}


/* show password */

togglePass.addEventListener("click",function(){

if(password.type==="password"){

password.type="text";
this.classList.replace("fa-eye","fa-eye-slash");

}else{

password.type="password";
this.classList.replace("fa-eye-slash","fa-eye");

}

});


/* image preview */

const fileInput=document.getElementById("file");
const preview=document.getElementById("previewImg");

fileInput.addEventListener("change",function(){

const file=this.files[0];

if(file){

preview.style.display="block";
preview.src=URL.createObjectURL(file);

}

});

</script>

</body>
</html>