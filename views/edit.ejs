<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Edit Post | Links.P9X9</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
font-family: Arial, sans-serif;
margin:0;
padding:0;
display:flex;
justify-content:center;
min-height:100vh;
}

.container{
width:95%;
max-width:600px;
}

.card{
padding:25px;
border-radius:10px;
}

h2{
text-align:center;
color:#333;
}

.input-group{
position:relative;
margin-bottom:15px;
}

.input-group i{
position:absolute;
top:50%;
left:12px;
transform:translateY(-50%);
color:#888;
}

.input-group input,
.input-group textarea{
width:80%;
padding:10px 10px 10px 40px;
border:1px solid #ddd;
border-radius:6px;
font-size:14px;
outline:none;
transition:0.3s;
margin:0 auto;
display:block;
}

.input-group textarea{
resize:none;
height:90px;
}

.input-group input:focus,
.input-group textarea:focus{
border-color:#007bff;
box-shadow:0 0 3px rgba(0,123,255,0.4);
}

button{
width:100%;
padding:12px;
background:#007bff;
border:none;
color:white;
font-size:16px;
border-radius:6px;
cursor:pointer;
transition:0.3s;
}

button:hover{
background:#0056b3;
}

@media (max-width:600px){

.card{
padding:20px;
}

h2{
font-size:20px;
}

}

</style>
</head>

<body>

<div class="container">

<% data.forEach(function(post) { %>

<div class="card">

<h2><i class="fa-solid fa-pen-to-square"></i> Edit Post</h2>

<form action="/edit/<%= post._id %>?_method=PUT" method="POST">

<div class="input-group">
<i class="fa-solid fa-link"></i>
<input name="routeName" value="<%= post.routeName %>" required>
</div>

<div class="input-group">
<i class="fa-solid fa-heading"></i>
<input name="title" value="<%= post.title %>">
</div>

<div class="input-group">
<i class="fa-solid fa-align-left"></i>
<textarea name="description"><%= post.description %></textarea>
</div>

<div class="input-group">
<i class="fa-solid fa-file-lines"></i>
<input name="shortDescription" value="<%= post.shortDescription %>">
</div>

<div class="input-group">
<i class="fa-solid fa-image"></i>
<input name="imageLink" value="<%= post.imageLink %>">
</div>

<div class="input-group">
<i class="fa-solid fa-video"></i>
<input name="videoLink" value="<%= post.videoLink %>">
</div>

<div class="input-group">
<i class="fa-solid fa-eye"></i>
<input name="totalView" type="number" value="<%= post.totalView %>">
</div>

<div class="input-group">
<i class="fa-solid fa-clock"></i>
<input name="duration" value="<%= post.duration %>">
</div>

<div class="input-group">
<i class="fa-solid fa-tags"></i>
<input name="category"
value="<%= Array.isArray(post.category) ? post.category.join(',') : post.category %>">
</div>

<div class="input-group">
<i class="fa-solid fa-calendar"></i>
<input type="text" name="updateDate" id="updateDate-<%= post._id %>">
</div>

<button type="submit">
<i class="fa-solid fa-save"></i> Update Post
</button>

</form>

</div>

<% }); %>

</div>

<script>
function getBDDateTime() {

const now = new Date();
const bd = new Date(now.getTime() + (6 * 60 * 60 * 1000));

const pad = n => n.toString().padStart(2, '0');

const year = bd.getUTCFullYear();
const month = pad(bd.getUTCMonth() + 1);
const day = pad(bd.getUTCDate());
const hours = pad(bd.getUTCHours());
const minutes = pad(bd.getUTCMinutes());
const seconds = pad(bd.getUTCSeconds());

return `${year}-${month}-${day}T${hours}:${minutes}:${seconds}+06:00`;

}

document.querySelectorAll('[id^="updateDate-"]').forEach(input => {
input.value = getBDDateTime();
});
</script>

</body>
</html>