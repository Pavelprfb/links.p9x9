<style>
  /* Basic Reset */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
  }

  body {
    background-color: #f4f4f4;
  }

  footer {
    background-color: #ffffff;
    border-top: 1px solid #e0e0e0;
    box-shadow: 0 -2px 8px rgba(0,0,0,0.05);
    padding: 30px 20px 15px 20px;
    color: #333;
  }

  .footer-container {
    max-width: 1200px;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  /* Logo / Website Name */
  .footer-logo {
    font-size: 28px;
    font-weight: bold;
    color: #222;
    text-decoration: none;
    text-align: center;
    letter-spacing: 1px;
    margin: 10px auto;
  }

  /* Footer Links */
  .footer-links {
    display: flex;
    gap: 25px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    text-decoration: none;
    color: #555;
    font-weight: 500;
    transition: all 0.3s;
    position: relative;
  }

  /* Hover effect underline */
  .footer-links a::after {
    content: '';
    display: block;
    height: 2px;
    width: 0;
    background: #007bff;
    transition: width 0.3s;
    position: absolute;
    bottom: -3px;
    left: 0;
  }

  .footer-links a:hover::after {
    width: 100%;
  }

  .footer-links a:hover {
    color: #007bff;
  }

  /* Footer Copyright */
  .footer-copy {
    text-align: center;
    font-size: 14px;
    color: #777;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-links {
      flex-direction: column;
      gap: 10px;
    }
  }
</style>

<footer>
  <div class="footer-container">
    <a href="/" class="footer-logo">Links.P9X9</a>

    
  </div>

  <div class="footer-copy">
    &copy; <span id="year"></span> Links.P9X9. All rights reserved.
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();
</script>
